{
  "amp.notifications.enabled": true,
  "amp.mcpServers": {
    "linear-server": {
      "url": "https://mcp.linear.app/mcp"
    },
    "linear": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ]
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    }
  },
  "amp.mcp.disable": [],
  "amp.tools.disable": [],
  "amp.commands.allowlist": [
    "pnpm",
    "git",
    "gh",
    "rm"
  ],
  "amp.dangerouslyAllowAll": true
}
