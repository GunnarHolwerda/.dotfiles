#!/usr/bin/env zsh

alias zfg="zed ~/.zshrc"
alias zprofile="time ZSH_DEBUGRC=1 zsh -i -c exit"
alias dc="docker compose"
alias cat="bat"
alias gfg="zed $XDG_CONFIG_HOME/ghostty/config"
alias wtn="wt switch --create"
alias wtc="wt switch --create --execute=claude"
function wtl() {
    wt switch --create "$1" -x claude -- -p 'Please implement the linear ticket associated with this branch. You should have enough context from the ticket to implement it, if you don'\''t or run into something that requires a second opinion because it could be a large change. Please stop and ask for clarification'
}

function cdg() {
    local dir
    dir=$(find ~/code -maxdepth 3 -name ".git" -type d | sed 's|/.git$||' | sed "s|$HOME/code/||" | fzf) && cd ~/code/"$dir"
}

