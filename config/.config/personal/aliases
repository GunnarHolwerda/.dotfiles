#!/usr/bin/env zsh

alias zfg="zed ~/.zshrc"
alias zprofile="time ZSH_DEBUGRC=1 zsh -i -c exit"
alias dc="docker compose"
alias tf="terraform"
alias cat="bat"
alias gfg="zed $XDG_CONFIG_HOME/ghostty/config"
alias wtn="git fetch origin && wt switch --create"
alias wtc="git fetch origin && wt switch --create --execute=claude"
alias wtl="git fetch origin && wt switch --create --execute=claude-linear"
alias wtr="wt remove"
alias claude="CLAUDE_CODE_NO_FLICKER=1 claude"
alias cdsp="claude --dangerously-skip-permissions"
alias claudex='CLAUDE_CODE_SUBAGENT_MODEL=gpt-5.6-sol \
CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1 \
CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=3 \
ENABLE_TOOL_SEARCH=false \
ANTHROPIC_BASE_URL=http://localhost:8317 \
claude --model gpt-5.6-sol'

function cdg() {
    local dir
    dir=$(find ~/code -maxdepth 3 -name ".git" -type d | sed 's|/.git$||' | sed "s|$HOME/code/||" | fzf) && cd ~/code/"$dir"
}

# Source local aliases (not checked into repo)
[[ -f $PERSONAL/aliases.local ]] && source $PERSONAL/aliases.local

