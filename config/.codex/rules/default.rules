prefix_rule(pattern=["gh", "run", "view"], decision="allow")
prefix_rule(pattern=["git", "add", "config/.claude/settings.json"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["pnpm", "test"], decision="allow")
prefix_rule(pattern=["git", ["diff", "status", "show", "blame", "log"]], decision="allow")
prefix_rule(pattern=["git", "--no-pager", "diff"], decision="allow")
prefix_rule(pattern=["git", "fetch"], decision="allow")
prefix_rule(pattern=["docker", "compose", ["ps", "logs"]], decision="allow")
prefix_rule(pattern=["aws", "logs", ["start-query", "get-query-results", "filter-log-events"]], decision="allow")
prefix_rule(pattern=["aws", "cloudwatch", "describe-alarms"], decision="allow")
prefix_rule(pattern=["aws", "application-autoscaling", "describe-scaling-policies"], decision="allow")
prefix_rule(pattern=["pnpm", ["typecheck", "type-check"]], decision="allow")
prefix_rule(pattern=["wt", "list"], decision="allow")
